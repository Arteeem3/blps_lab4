{
  "executionPlatform": "Camunda Platform",
  "executionPlatformVersion": "7.21",
  "exporter": {
    "name": "Camunda Modeler",
    "version": "5.22.0"
  },
  "schemaVersion": 11,
  "components": [
    {
      "text": "# Подтверждение актуальности объявления",
      "type": "text",
      "id": "Field_1"
    },
    {
      "label": "ID объявления",
      "type": "number",
      "layout": {
        "row": "Row_1",
        "columns": null
      },
      "id": "Field_listingId",
      "key": "listingId",
      "validate": {
        "required": true
      }
    },
    {
      "label": "Объявление всё ещё актуально? (Оставить = Да, Снять = Нет)",
      "type": "checkbox",
      "layout": {
        "row": "Row_2",
        "columns": null
      },
      "id": "Field_relevant",
      "key": "relevant",
      "defaultValue": true
    }
  ],
  "type": "default",
  "id": "listing-renew-start"
}

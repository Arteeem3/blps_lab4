<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xmlns:camunda="http://camunda.org/schema/1.0/bpmn"
             xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
             xmlns:omgdc="http://www.omg.org/spec/DD/20100524/DC"
             xmlns:omgdi="http://www.omg.org/spec/DD/20100524/DI"
             targetNamespace="http://bpmn.io/schema/bpmn"
             id="listing-expiry-check-definitions">

  <process id="listing-expiry-check" name="[TIMER] Проверка сроков объявлений" isExecutable="true"
           camunda:historyTimeToLive="180"
           camunda:candidateStarterGroups="ADMIN">

    <startEvent id="start" name="Ежедневно в 3:00">
      <outgoing>flow-start-to-check</outgoing>
      <timerEventDefinition>
        <timeCycle>0 0 3 * * ?</timeCycle>
      </timerEventDefinition>
    </startEvent>

    <serviceTask id="task-check" name="Проверить сроки" camunda:delegateExpression="${listingExpiryCheckDelegate}">
      <incoming>flow-start-to-check</incoming>
      <outgoing>flow-check-to-report</outgoing>
    </serviceTask>

    <userTask id="task-report" name="Отчёт"
              camunda:formKey="camunda-forms:deployment:listing-expiry-check-result.form"
              camunda:candidateGroups="ADMIN"
              camunda:assignee="admin">
      <incoming>flow-check-to-report</incoming>
      <outgoing>flow-report-to-end</outgoing>
    </userTask>

    <endEvent id="end" name="Конец">
      <incoming>flow-report-to-end</incoming>
    </endEvent>

    <sequenceFlow id="flow-start-to-check" sourceRef="start" targetRef="task-check" />
    <sequenceFlow id="flow-check-to-report" sourceRef="task-check" targetRef="task-report" />
    <sequenceFlow id="flow-report-to-end" sourceRef="task-report" targetRef="end" />

  </process>

  <bpmndi:BPMNDiagram id="BPMNDiagram_listing_expiry_check">
    <bpmndi:BPMNPlane id="BPMNPlane_listing_expiry_check" bpmnElement="listing-expiry-check">
      <bpmndi:BPMNShape id="shape-start" bpmnElement="start">
        <omgdc:Bounds x="150" y="82" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="shape-task-check" bpmnElement="task-check">
        <omgdc:Bounds x="270" y="60" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="shape-task-report" bpmnElement="task-report">
        <omgdc:Bounds x="470" y="60" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="shape-end" bpmnElement="end">
        <omgdc:Bounds x="670" y="82" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="edge-flow-start-to-check" bpmnElement="flow-start-to-check">
        <omgdi:waypoint x="186" y="100" />
        <omgdi:waypoint x="270" y="100" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="edge-flow-check-to-report" bpmnElement="flow-check-to-report">
        <omgdi:waypoint x="370" y="100" />
        <omgdi:waypoint x="470" y="100" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="edge-flow-report-to-end" bpmnElement="flow-report-to-end">
        <omgdi:waypoint x="570" y="100" />
        <omgdi:waypoint x="670" y="100" />
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>

</definitions>
<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xmlns:camunda="http://camunda.org/schema/1.0/bpmn"
             xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
             xmlns:omgdc="http://www.omg.org/spec/DD/20100524/DC"
             xmlns:omgdi="http://www.omg.org/spec/DD/20100524/DI"
             targetNamespace="http://bpmn.io/schema/bpmn"
             id="listing-create-definitions">
  <process id="listing-create" name="[POST] Создать объявление" isExecutable="true" camunda:historyTimeToLive="180" camunda:candidateStarterGroups="SELLER,ADMIN">
    <startEvent camunda:initiator="starter" id="start" camunda:formKey="camunda-forms:deployment:listing-create.form">
      <outgoing>flow-start-to-create</outgoing>
    </startEvent>

    <serviceTask id="task-create" name="Создать" camunda:delegateExpression="${listingCreateDelegate}">
      <incoming>flow-start-to-create</incoming>
      <outgoing>flow-create-to-result</outgoing>
    </serviceTask>

    <userTask id="task-result" name="Результат" camunda:formKey="camunda-forms:deployment:listing-create-result.form" camunda:assignee="${starter}" camunda:candidateGroups="SELLER,ADMIN">
      <extensionElements>
        <camunda:inputOutput>
           <camunda:inputParameter name="starter">${execution.getVariable('starter') == null ? 'demo' : starter}</camunda:inputParameter>
        </camunda:inputOutput>
      </extensionElements>
      <incoming>flow-create-to-result</incoming>
      <outgoing>flow-result-to-end</outgoing>
    </userTask>

    <endEvent id="end">
      <incoming>flow-result-to-end</incoming>
    </endEvent>

    <sequenceFlow id="flow-start-to-create" sourceRef="start" targetRef="task-create"/>
    <sequenceFlow id="flow-create-to-result" sourceRef="task-create" targetRef="task-result"/>
    <sequenceFlow id="flow-result-to-end" sourceRef="task-result" targetRef="end"/>
  </process>

  <bpmndi:BPMNDiagram id="BPMNDiagram_listing-create">
    <bpmndi:BPMNPlane id="BPMNPlane_listing-create" bpmnElement="listing-create">
      <bpmndi:BPMNShape id="start_di" bpmnElement="start"><omgdc:Bounds x="150" y="100" width="36" height="36"/></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="task-create_di" bpmnElement="task-create"><omgdc:Bounds x="250" y="78" width="100" height="80"/></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="task-result_di" bpmnElement="task-result"><omgdc:Bounds x="400" y="78" width="100" height="80"/></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="end_di" bpmnElement="end"><omgdc:Bounds x="550" y="100" width="36" height="36"/></bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="flow-start-to-create_di" bpmnElement="flow-start-to-create"><omgdi:waypoint x="186" y="118"/><omgdi:waypoint x="250" y="118"/></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="flow-create-to-result_di" bpmnElement="flow-create-to-result"><omgdi:waypoint x="350" y="118"/><omgdi:waypoint x="400" y="118"/></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="flow-result-to-end_di" bpmnElement="flow-result-to-end"><omgdi:waypoint x="500" y="118"/><omgdi:waypoint x="550" y="118"/></bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</definitions>